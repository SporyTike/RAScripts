        duelistIDs,
        fallback = "an unknown Duelist"
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getOpponentLifePoints() / 1000),
               measured(8000 / 1000, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
