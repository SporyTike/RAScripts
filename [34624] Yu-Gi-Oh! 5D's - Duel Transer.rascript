//--------------------------------------------------
// Addresses
Mem_GameState                = 0x005713d8
Mem_GameMode                 = 0x005713fc
Mem_PlayerDesignID           = 0x00571438
Mem_MapID                    = 0x005714bd
Mem_CardDataStart            = 0x005715f3
Mem_StoryPointer             = 0x009f8470
Mem_APsInSavefile            = 0x00577f1c
Mem_RouletteRollsInSavefile  = 0x00577c64
Mem_TileCompletionInSavefile = 0x00577ca7
Mem_PointerOpponentData      = 0x00579868
Mem_PlayerLifePoints         = 0x00662688
Mem_OpponentLifePoints       = 0x006631c4
Mem_DuelPhase                = 0x0066574c

pointerMask = 0x3fffffff

//--------------------------------------------------
// Functions

function pseudoImpossibleCondition() {
    return checkGameState(0x00000000, 0xFFFFFFFF)
}

function checkGameState(mainState, subState) {
    return checkMainState(mainState) &&
           checkSubState(subState)
} 

function checkMainState(mainState) {
    return dword_be(Mem_GameState + 0x00) == mainState
}

function checkSubState(subState) {
    return dword_be(Mem_GameState + 0x04) == subState
}

function checkGameMode(gameMode) {
    return byte(Mem_GameMode) == gameMode
}

function getPlayerDesignID() {
    return byte(Mem_PlayerDesignID)
}

function getActionID() {
    return (dword_be(Mem_GameState + 0x00) & 0xFFFF) * 0x10000 +
           (dword_be(Mem_GameState + 0x04) & 0xFFFF)
}

function getCurrentMapID() {
    return byte(Mem_MapID)
}

function getCurrentMapIDWhileRoaming() {
    return dword_be((dword_be(Mem_StoryPointer) & pointerMask) + 0x1388)
}

function getRouletteRollsInSavefile() {
    return dword_be(Mem_RouletteRollsInSavefile)
}

function getRouletteRollsWhileRoaming() {
    return dword_be((dword_be(Mem_StoryPointer) & pointerMask) + 0x138C)
}

function getRouletteRollsInSavefile() {
    return dword_be(Mem_RouletteRollsInSavefile)
}

function getAPsWhileRoaming() {
    return dword_be((dword_be(Mem_StoryPointer) & pointerMask) + 0x1390)
}

function getAPsInSavefile() {
    return dword_be(Mem_APsInSavefile)
}

function checkCardOwned(cardName) {
    return any_of(array_filter(cardOffsets, cardOffset => cardOffsets[cardOffset] == cardName), cardOffset => byte(Mem_CardDataStart + (cardOffset * 2)) / byte(Mem_CardDataStart + (cardOffset * 2)))
}

function getOpponentDuelistID() {
    return byte((dword_be(Mem_PointerOpponentData) & pointerMask) + 0x801E8 + 0x03)
}

function getPlayerLifePoints() {
    return dword_be(Mem_PlayerLifePoints)
}

function getOpponentLifePoints() {
    return dword_be(Mem_OpponentLifePoints)
}

function getDuelPhase() {
    return dword_be(Mem_DuelPhase)
}

function showDefaultLifePointsDuringBattleInitialization() {
    return tally(1, checkGameState(0x05, 0x00) &&
                    never(checkGameState(0x04, 0x00) &&
                          prev(getDuelPhase() == 0x07) &&
                               getDuelPhase() != 0x07), 
                    checkGameState(0x03, 0x11) &&
                    never(checkGameState(0x04, 0x00) &&
                          prev(getDuelPhase() == 0x07) &&
                               getDuelPhase() != 0x07), 
                    checkGameState(0x03, 0x21) &&
                    never(checkGameState(0x04, 0x00) &&
                          prev(getDuelPhase() == 0x07) &&
                               getDuelPhase() != 0x07))
                    
}

function checkMapCoordinateWhileRoaming(yAxis, xAxis) {
    return dword_be((dword_be(Mem_StoryPointer) & pointerMask) + 0x13EC) == xAxis &&
           dword_be((dword_be(Mem_StoryPointer) & pointerMask) + 0x13F0) == yAxis        
}

function checkMapTileCompletionWhileRoaming(yAxis, xAxis, type) {
    address = (dword_be(Mem_StoryPointer) & pointerMask) + 0x5B7 + (xAxis) + (yAxis * 18)
    if (type == "Item") {
        return bit5(address)
    }
    if (type == "Duelist") {
        return bit3(address) * bit6(address)
    }   
}

function checkMapTileCompletionInSavefile(yAxis, xAxis, type) {
    address = Mem_TileCompletionInSavefile + (xAxis) + (yAxis * 18)
    if (type == "Item") {
        return bit5(address)
    }
    if (type == "Duelist") {
        return bit3(address) * bit6(address)
    }   
}

function getMapClear() {
    return prev(dword_be((dword_be(Mem_StoryPointer) & pointerMask))) != 0x06 &&
                dword_be((dword_be(Mem_StoryPointer) & pointerMask))  == 0x06
}

//--------------------------------------------------
// Achievements

achievement(
    title = "A Little Magic Right at the Beginning", type = "missable",
    description = "Start your adventure as Dark Magician or Dark Magician Girl.",
    id = 600785, badge = "681671", points = 2,
    trigger = checkGameState(0x03, 0x1C) &&
              getPlayerDesignID() != prev(getPlayerDesignID()) &&
              __ornext(getPlayerDesignID() == 0x06 ||
                       getPlayerDesignID() == 0x0D)
)

achievement(
    title = "Entering the World Tower", type = "progression",
    description = "Clear the Yggdrasil Entrance and reach the next floor.",
    id = 600959, badge = "681989", points = 5,
    trigger = checkGameState(0x05, 0x00) &&
               checkMapCoordinateWhileRoaming(0x03, 0x0C) &&
               getMapClear() &&
               getCurrentMapID() == 0x01
)

achievement(
    title = "Clear Without Fear", type = "",
    description = "Clear the Yggdrasil Entrance with 100% item and duelist completion.",
    id = 600960, badge = "681990", points = 10,
    trigger = (checkGameState(0x05, 0x00) &&
               checkMapCoordinateWhileRoaming(0x03, 0x0C) &&
               getMapClear() &&
               measured(checkMapTileCompletionWhileRoaming(0x00, 0x07, "Item")
                      + checkMapTileCompletionWhileRoaming(0x00, 0x0A, "Item")
                      + checkMapTileCompletionWhileRoaming(0x02, 0x05, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x02, 0x09, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x02, 0x0B, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x03, 0x01, "Item")
                      + checkMapTileCompletionWhileRoaming(0x03, 0x02, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x04, 0x04, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x04, 0x06, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x04, 0x08, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x05, 0x06, "Item")
                      + checkMapTileCompletionWhileRoaming(0x05, 0x07, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x05, 0x08, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x05, 0x0A, "Duelist")
                      + checkMapTileCompletionWhileRoaming(0x05, 0x0B, "Item") == 15, format="percent", when = checkGameMode(0x03) && getCurrentMapID() == 0x01 &&  checkMainState(0x05))) ||
              (pseudoImpossibleCondition() &&
               measured(checkMapTileCompletionInSavefile(0x00, 0x07, "Item")
                      + checkMapTileCompletionInSavefile(0x00, 0x0A, "Item")
                      + checkMapTileCompletionInSavefile(0x02, 0x05, "Duelist")
                      + checkMapTileCompletionInSavefile(0x02, 0x09, "Duelist")
                      + checkMapTileCompletionInSavefile(0x02, 0x0B, "Duelist")
                      + checkMapTileCompletionInSavefile(0x03, 0x01, "Item")
                      + checkMapTileCompletionInSavefile(0x03, 0x02, "Duelist")
                      + checkMapTileCompletionInSavefile(0x04, 0x04, "Duelist")
                      + checkMapTileCompletionInSavefile(0x04, 0x06, "Duelist")
                      + checkMapTileCompletionInSavefile(0x04, 0x08, "Duelist")
                      + checkMapTileCompletionInSavefile(0x05, 0x06, "Item")
                      + checkMapTileCompletionInSavefile(0x05, 0x07, "Duelist")
                      + checkMapTileCompletionInSavefile(0x05, 0x08, "Duelist")
                      + checkMapTileCompletionInSavefile(0x05, 0x0A, "Duelist")
                      + checkMapTileCompletionInSavefile(0x05, 0x0B, "Item") == 15, format="percent", when = checkGameMode(0x03) && getCurrentMapID() == 0x01 && !checkMainState(0x05)))
)

