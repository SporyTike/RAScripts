                      + checkMapTileCompletionWhileRoaming(0x04, 0x08, "Item")
                      + checkMapTileCompletionWhileRoaming(0x05, 0x05, "Duelist") == 15, format="percent", when = checkGameMode(0x03) && getCurrentMapID() == 0x0F &&  checkMainState(0x05))) ||
              (pseudoImpossibleCondition() &&
               measured(checkMapTileCompletionInSavefile(0x00, 0x03, "Item")
                      + checkMapTileCompletionInSavefile(0x00, 0x04, "Duelist")
                      + checkMapTileCompletionInSavefile(0x00, 0x07, "Item")
                      + checkMapTileCompletionInSavefile(0x01, 0x06, "Item")
                      + checkMapTileCompletionInSavefile(0x01, 0x08, "Item")
                      + checkMapTileCompletionInSavefile(0x01, 0x0A, "Duelist")
                      + checkMapTileCompletionInSavefile(0x02, 0x06, "Item")
                      + checkMapTileCompletionInSavefile(0x02, 0x0A, "Duelist")
                      + checkMapTileCompletionInSavefile(0x03, 0x02, "Item")
                      + checkMapTileCompletionInSavefile(0x05, 0x03, "Item")
                      + checkMapTileCompletionInSavefile(0x05, 0x08, "Item")
                      + checkMapTileCompletionInSavefile(0x05, 0x09, "Item")
                      + checkMapTileCompletionInSavefile(0x05, 0x0A, "Item")
                      + checkMapTileCompletionInSavefile(0x04, 0x08, "Item")
                      + checkMapTileCompletionInSavefile(0x05, 0x05, "Duelist") == 15, format="percent", when = checkGameMode(0x03) && getCurrentMapID() == 0x0F && !checkMainState(0x05)))
)

//--------------------------------------------------
// Rich Presence

rich_presence_conditional_display((checkGameMode(0x01) || checkGameMode(0x02)) && (checkGameState(0x03, 0x14) || checkGameState(0x03, 0x1B) || checkGameState(0x03, 0x1C)),
    "In the File Select"
)

rich_presence_conditional_display(checkGameMode(0x00) || checkGameMode(0x01),
    "In the Titlescreen"
)

rich_presence_conditional_display(checkGameState(0x05, 0x00),
    "{0} is {1} [{2} AP] [🎲{3}] [Story]",
    rich_presence_lookup(
        "PlayerDesignIDs",
        getPlayerDesignID(),
        playerDesignIDs,
        fallback = "A Duelist"
    ),
    rich_presence_lookup(
        "mapIDs",
        getCurrentMapID(),
        mapIDs,
        fallback = mapIDs[1]
    ),
    rich_presence_value(
        "Number", 
        measured(getAPsWhileRoaming(), when = getCurrentMapIDWhileRoaming() == getCurrentMapID()),
        "VALUE"
    ),
    rich_presence_value(
        "Number", 
        measured(getRouletteRollsWhileRoaming(), when = getCurrentMapIDWhileRoaming() == getCurrentMapID()),
        "VALUE"
    )
)

rich_presence_conditional_display(checkGameMode(0x03) && checkGameState(0x04, 0x00),
    "{0} [LP|{1}{2}{3}{4}] is dueling against {5} [LP|{6}{7}{8}{9}] {10} [{11} AP] [🎲{12}] [Story]",
    rich_presence_lookup(
        "PlayerDesignIDs",
        getPlayerDesignID(),
        playerDesignIDs,
        fallback = "A Duelist"
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getPlayerLifePoints() / 1000),
               measured(8000 / 1000, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
        fallback = ""
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getPlayerLifePoints() / 100),
               measured(8000 / 100, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
        fallback = ""
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getPlayerLifePoints() / 10),
               measured(8000 / 10, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
        fallback = ""
    ),
    rich_presence_value(
        "Unformatted", 
        max_of(measured(getPlayerLifePoints()),
               measured(8000, when = showDefaultLifePointsDuringBattleInitialization())),
        "VALUE"
    ),
    rich_presence_lookup(
        "DuelistIDs",
        getOpponentDuelistID(),
        duelistIDs,
        fallback = "an unknown Duelist"
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getOpponentLifePoints() / 1000),
               measured(8000 / 1000, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
        fallback = ""
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getOpponentLifePoints() / 100),
               measured(8000 / 100, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
        fallback = ""
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getOpponentLifePoints() / 10),
               measured(8000 / 10, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
        fallback = ""
    ),
    rich_presence_value(
        "Unformatted", 
        max_of(measured(getOpponentLifePoints()),
               measured(8000, when = showDefaultLifePointsDuringBattleInitialization())),
        "VALUE"
    ),
    rich_presence_lookup(
        "mapIDs",
        getCurrentMapID(),
        mapIDs,
        fallback = mapIDs[1]
    ),
    rich_presence_value(
        "Number", 
        measured(getAPsInSavefile()),
        "VALUE"
    ),
    rich_presence_value(
        "Number", 
        measured(getRouletteRollsInSavefile()),
        "VALUE"
    )
)

rich_presence_conditional_display(checkGameMode(0x04) && checkGameState(0x04, 0x00),
    "{0} [LP|{1}{2}{3}{4}] is dueling against {5} [LP|{6}{7}{8}{9}] [Free Duel]",
    rich_presence_lookup(
        "PlayerDesignIDs",
        getPlayerDesignID(),
        playerDesignIDs,
        fallback = "A Duelist"
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getPlayerLifePoints() / 1000),
               measured(8000 / 1000, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
        fallback = ""
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getPlayerLifePoints() / 100),
               measured(8000 / 100, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
        fallback = ""
    ),
    rich_presence_lookup(
        "fillerNull",
        max_of(measured(getPlayerLifePoints() / 10),
               measured(8000 / 10, when = showDefaultLifePointsDuringBattleInitialization())),
        fillerNull,
        fallback = ""
    ),
    rich_presence_value(
        "Unformatted", 
        max_of(measured(getPlayerLifePoints()),
               measured(8000, when = showDefaultLifePointsDuringBattleInitialization())),
        "VALUE"
    ),
    rich_presence_lookup(
        "DuelistIDs",
